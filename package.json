{
  "name": "pi-dcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Branch-aware agentic dynamic context pruning for Pi",
  "author": "nostalfinals",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi",
    "context-management",
    "context-compression",
    "agentic"
  ],
  "files": [
    "index.ts",
    "lib/**/*.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "test": "tsx --test test/**/*.test.ts",
    "verify": "npm run check && npm test"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "0.80.10",
    "@earendil-works/pi-coding-agent": "0.80.10",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=20"
  }
}
